{
  "name": "ckiller",
  "version": "1.0.0",
  "description": "Claude Skill and Subagent runner.",
  "private": true,
  "author": "Subhasish Biswasray",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biswasray/ckiller.git"
  },
  "bugs": {
    "url": "https://github.com/biswasray/ckiller/issues"
  },
  "homepage": "https://github.com/biswasray/ckiller#readme",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "ckiller": "./packages/server/dist/index.js",
    "ckiller-dev": "./dev-cli.mjs"
  },
  "scripts": {
    "build": "lerna run build",
    "dev": "lerna run dev --parallel",
    "dev:server": "lerna run dev --parallel --scope @ckiller/universe --scope @ckiller/server",
    "dev:client": "lerna run dev --parallel --scope @ckiller/universe --scope@ckiller/client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "lerna run typecheck",
    "clean": "lerna run clean",
    "test": "lerna run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.12.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "lerna": "^8.1.5",
    "prettier": "^3.8.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.1"
  }
}
