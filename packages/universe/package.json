{
  "name": "@ckiller/universe",
  "version": "1.0.0",
  "description": "Shared utils and constants for ckiller.",
  "main": "./dist/cjs/index.node.js",
  "module": "./dist/esm/index.node.js",
  "types": "./src/index.node.ts",
  "exports": {
    ".": {
      "types": "./src/index.node.ts",
      "browser": "./src/index.browser.ts",
      "import": "./src/index.node.ts",
      "require": "./dist/cjs/index.node.js",
      "default": "./dist/cjs/index.node.js"
    },
    "./node": {
      "types": "./src/index.node.ts",
      "import": "./dist/esm/index.node.js",
      "require": "./dist/cjs/index.node.js",
      "default": "./dist/cjs/index.node.js"
    },
    "./browser": {
      "types": "./dist/esm/index.browser.d.ts",
      "import": "./dist/esm/index.browser.js",
      "default": "./dist/esm/index.browser.js"
    },
    "./typescripts": "./src/index.node.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "tsc -watch -p tsconfig.json & tsc -watch -p tsconfig.esm.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "echo \"(universe) no tests\" && exit 0"
  },
  "license": "ISC"
}
