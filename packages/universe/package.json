{
  "name": "@ckiller/universe",
  "version": "1.0.0",
  "description": "Shared utils and constants for ckiller.",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "ISC",
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "tsc -watch -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "echo \"(universe) no tests\" && exit 0"
  }
}
